generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ArticleStatus {
  NOT_ASSIGNED
  ASSIGNED
  DRAFT_RECEIVED
  COMPLETED
  PUBLISHED
  CANCELED
}

enum TopicPriority {
  HIGH
  MEDIUM
  LOW
}

enum TopicContentType {
  INFORMATIONAL
  TRANSACTIONAL
  COMPARISON
  LISTICLE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  topics    Article[]
}

model Article {
  id                 String               @id @default(cuid())
  topicNumber        Int                  @unique @default(autoincrement())
  projectId          String
  title              String
  titleNormalized    String
  brief              String
  primaryKeywords    String
  secondaryKeywords  String?
  writerName         String?
  delegatedAt        DateTime?
  dueMonth           String?
  publishUrl         String?
  status             ArticleStatus        @default(NOT_ASSIGNED)
  priority           TopicPriority        @default(MEDIUM)
  contentType        TopicContentType     @default(INFORMATIONAL)
  publishedAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  project            Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  statusHistory      TopicStatusHistory[]

  @@index([projectId])
  @@index([status])
  @@index([writerName])
  @@index([dueMonth])
  @@index([titleNormalized])
  @@index([publishedAt])
}

model TopicStatusHistory {
  id         String        @id @default(cuid())
  articleId  String
  fromStatus ArticleStatus?
  toStatus   ArticleStatus
  writerName String?
  changedAt  DateTime      @default(now())
  article    Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, changedAt])
}
